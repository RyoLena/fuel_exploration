<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="fusion_bot">
    <pose>0 0 0 0 0 0</pose>

    <!-- ==================== Links ==================== -->

    <link name="base_footprint"/>

    <!-- Chassis -->
    <link name="base_link">
      <inertial>
        <pose>0 0 0.06 0 0 0</pose>
        <mass>2.0</mass>
        <inertia>
          <ixx>8.33e-3</ixx>  <ixy>0</ixy>  <ixz>0</ixz>
          <iyy>1.67e-2</iyy>  <iyz>0</iyz>
          <izz>2.17e-2</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <pose>0 0 0.06 0 0 0</pose>
        <geometry>
          <box><size>0.30 0.20 0.10</size></box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <pose>0 0 0.06 0 0 0</pose>
        <geometry>
          <box><size>0.30 0.20 0.10</size></box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.4 0.4 0.4 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Left wheel -->
    <link name="wheel_left_link">
      <inertial>
        <pose>0 0.10 0.033 -1.5708 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>3.0e-5</ixx>  <ixy>0</ixy>  <ixz>0</ixz>
          <iyy>3.0e-5</iyy>  <iyz>0</iyz>
          <izz>5.4e-5</izz>
        </inertia>
      </inertial>
      <collision name="wheel_left_collision">
        <pose>0 0.10 0.033 -1.5708 0 0</pose>
        <geometry>
          <cylinder><radius>0.033</radius><length>0.018</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>100000</mu><mu2>100000</mu2></ode>
          </friction>
          <contact>
            <ode>
              <kp>1e5</kp><kd>1</kd>
              <max_vel>0.01</max_vel><min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="wheel_left_visual">
        <pose>0 0.10 0.033 -1.5708 0 0</pose>
        <geometry>
          <cylinder><radius>0.033</radius><length>0.018</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="wheel_right_link">
      <inertial>
        <pose>0 -0.10 0.033 -1.5708 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>3.0e-5</ixx>  <ixy>0</ixy>  <ixz>0</ixz>
          <iyy>3.0e-5</iyy>  <iyz>0</iyz>
          <izz>5.4e-5</izz>
        </inertia>
      </inertial>
      <collision name="wheel_right_collision">
        <pose>0 -0.10 0.033 -1.5708 0 0</pose>
        <geometry>
          <cylinder><radius>0.033</radius><length>0.018</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>100000</mu><mu2>100000</mu2></ode>
          </friction>
          <contact>
            <ode>
              <kp>1e5</kp><kd>1</kd>
              <max_vel>0.01</max_vel><min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="wheel_right_visual">
        <pose>0 -0.10 0.033 -1.5708 0 0</pose>
        <geometry>
          <cylinder><radius>0.033</radius><length>0.018</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Rear caster (frictionless ball) -->
    <link name="caster_link">
      <pose>-0.12 0 0.006 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>  <ixy>0</ixy>  <ixz>0</ixz>
          <iyy>1e-6</iyy>  <iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <collision name="caster_collision">
        <geometry>
          <sphere><radius>0.01</radius></sphere>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0</mu><mu2>0</mu2></ode>
          </friction>
          <contact>
            <ode>
              <kp>1e5</kp><kd>1</kd>
              <max_vel>0.01</max_vel><min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
    </link>

    <!-- IMU (massless, sensor only) -->
    <link name="imu_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>200</update_rate>
        <topic>imu</topic>
        <gz_frame_id>imu_link</gz_frame_id>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <!-- 3D LiDAR (VLP-16 style) -->
    <link name="lidar_link">
      <inertial>
        <pose>0 0 0.16 0 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>4.0e-4</ixx>  <ixy>0</ixy>  <ixz>0</ixz>
          <iyy>4.0e-4</iyy>  <iyz>0</iyz>
          <izz>4.0e-4</izz>
        </inertia>
      </inertial>
      <collision name="lidar_collision">
        <pose>0 0 0.16 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.04</radius><length>0.07</length></cylinder>
        </geometry>
      </collision>
      <visual name="lidar_visual">
        <pose>0 0 0.16 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.04</radius><length>0.07</length></cylinder>
        </geometry>
        <material>
          <ambient>0.0 0.0 0.8 1.0</ambient>
          <diffuse>0.0 0.0 0.8 1.0</diffuse>
        </material>
      </visual>
      <sensor name="velodyne_vlp16" type="gpu_lidar">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <pose>0 0 0.16 0 0 0</pose>
        <update_rate>10</update_rate>
        <topic>lidar</topic>
        <gz_frame_id>lidar_link</gz_frame_id>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>6.28318</max_angle>
            </horizontal>
            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-0.261799</min_angle>
              <max_angle>0.261799</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.3</min>
            <max>100.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </link>

    <!-- Camera -->
    <link name="camera_link"/>

    <link name="camera_rgb_frame">
      <inertial>
        <pose>0.15 0 0.08 0 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>6.1e-5</ixx>  <ixy>0</ixy>  <ixz>0</ixz>
          <iyy>1.5e-5</iyy>  <iyz>0</iyz>
          <izz>6.1e-5</izz>
        </inertia>
      </inertial>
      <collision name="camera_collision">
        <pose>0.15 0 0.08 0 0 0</pose>
        <geometry>
          <box><size>0.03 0.08 0.03</size></box>
        </geometry>
      </collision>
      <visual name="camera_visual">
        <pose>0.15 0 0.08 0 0 0</pose>
        <geometry>
          <box><size>0.03 0.08 0.03</size></box>
        </geometry>
        <material>
          <ambient>0.8 0.0 0.0 1.0</ambient>
          <diffuse>0.8 0.0 0.0 1.0</diffuse>
        </material>
      </visual>
      <sensor name="rgb_camera" type="camera">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>30</update_rate>
        <topic>camera/image_raw</topic>
        <gz_frame_id>camera_optical_frame</gz_frame_id>
        <camera name="front_camera">
          <camera_info_topic>camera/camera_info</camera_info_topic>
          <horizontal_fov>1.2217</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.02</near>
            <far>300</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </link>

    <!-- ==================== Joints ==================== -->

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose>0 0 0.010 0 0 0</pose>
    </joint>

    <joint name="wheel_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <pose>0 0.10 0.033 -1.5708 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><effort>20</effort></limit>
      </axis>
    </joint>

    <joint name="wheel_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <pose>0 -0.10 0.033 -1.5708 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><effort>20</effort></limit>
      </axis>
    </joint>

    <joint name="caster_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_link</child>
    </joint>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
      <pose>0 0 0.06 0 0 0</pose>
    </joint>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
      <pose>0 0 0.16 0 0 0</pose>
    </joint>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
      <pose>0.15 0 0.08 0 0 0</pose>
    </joint>

    <joint name="camera_rgb_joint" type="fixed">
      <parent>camera_link</parent>
      <child>camera_rgb_frame</child>
    </joint>

    <!-- ==================== Plugins ==================== -->

    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.20</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publisher_frequency>30</odom_publisher_frequency>
      <tf_topic>/tf</tf_topic>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
    </plugin>

  </model>
</sdf>

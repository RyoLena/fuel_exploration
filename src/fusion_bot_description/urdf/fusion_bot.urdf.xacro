<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fusion_bot">

  <!-- ==================== Links ==================== -->

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry><box size="0.30 0.20 0.10"/></geometry>
      <material name="dark_grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry><box size="0.30 0.20 0.10"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="8.33e-3" ixy="0" ixz="0"
               iyy="1.67e-2" iyz="0" izz="2.17e-2"/>
    </inertial>
  </link>

  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.018"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.018"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="3.0e-5" ixy="0" ixz="0"
               iyy="3.0e-5" iyz="0" izz="5.4e-5"/>
    </inertial>
  </link>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.018"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.018"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="3.0e-5" ixy="0" ixz="0"
               iyy="3.0e-5" iyz="0" izz="5.4e-5"/>
    </inertial>
  </link>

  <link name="caster_link">
    <collision>
      <geometry><sphere radius="0.01"/></geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="4.0e-4" ixy="0" ixz="0"
               iyy="4.0e-4" iyz="0" izz="4.0e-4"/>
    </inertial>
  </link>

  <link name="imu_link"/>

  <link name="camera_link"/>

  <link name="camera_rgb_frame">
    <visual>
      <geometry><box size="0.03 0.08 0.03"/></geometry>
      <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.03 0.08 0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.1e-5" ixy="0" ixz="0"
               iyy="1.5e-5" iyz="0" izz="6.1e-5"/>
    </inertial>
  </link>

  <link name="camera_optical_frame"/>

  <!-- ==================== Joints ==================== -->

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.010" rpy="0 0 0"/>
  </joint>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 0.10 0.023" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -0.10 0.023" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.12 0 -0.004" rpy="0 0 0"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.15 0 0.07" rpy="0 0 0"/>
  </joint>

  <joint name="camera_rgb_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_rgb_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Optical frame: z-forward, x-right, y-down -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_rgb_frame"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

</robot>
